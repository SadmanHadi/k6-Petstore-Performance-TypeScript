{
  "compilerOptions": {
    "target": "es2015",
    "module": "es6",
    "lib": ["es2015", "es2016", "es2017", "dom"],
    "moduleResolution": "node",
    "outDir": "dist",
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "*": ["src/*"]
    },
    "esModuleInterop": true,
    "allowJs": true,
    "declaration": false,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*"]
}
